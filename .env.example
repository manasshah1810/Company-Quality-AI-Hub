# Cogniify Quality AI Hub - Environment Configuration
# Copy this file to .env and fill in with actual values

# ================================================================================
# ANTHROPIC API KEY
# ================================================================================
# Required for AI-powered test generation, healing, and validation features
# Get your key from: https://console.anthropic.com/
VITE_ANTHROPIC_API_KEY=sk-ant-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ================================================================================
# FIREBASE CONFIGURATION
# ================================================================================
# Path to Firebase service account JSON file (for admin SDK)
# Download from Firebase Console > Project Settings > Service Accounts
# Can also be a JSON string for deployment platforms (Render, Heroku, etc.)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/firebase-service-key.json

# ================================================================================
# BACKEND SERVER
# ================================================================================
# Port the Express backend server will listen on (default: 5003)
PORT=5003

# ================================================================================
# FRONTEND API URL (FOR PRODUCTION)
# ================================================================================
# In development, the Vite proxy handles API routing to localhost:5003
# In production, set this to your deployed backend URL
# VITE_API_URL=https://your-backend-domain.com

# ================================================================================
# NOTES FOR DEPLOYMENT
# ================================================================================
# 1. Set GOOGLE_APPLICATION_CREDENTIALS to the Firebase service account path
# 2. Ensure VITE_ANTHROPIC_API_KEY is set with a valid API key
# 3. Firebase project ID is hardcoded as "hub-dev-2b1dd" in the code
# 4. For Render/Heroku: GOOGLE_APPLICATION_CREDENTIALS should be a JSON string, not a file path
